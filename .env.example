# Email delivery for contact and booking forms
# Get a key at https://resend.com (free tier is sufficient)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where submissions and booking requests should land (SoftBase Labs inbox)
# Change only if you use a different monitored address
CONTACT_EMAIL=softbaselabs@gmail.com

# Optional: set to "true" or "1" during development or provider-swap testing
# to use the console-only mock instead of calling the real provider.
# This lets you test the full success/error UI + logging path with zero emails sent.
MOCK_EMAIL=false
